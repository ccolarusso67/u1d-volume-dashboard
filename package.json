{
  "name": "u1d-volume-dashboard",
  "version": "0.1.0",
  "private": true,
  "engines": {
    "node": ">=20.0.0"
  },
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "start": "next start",
    "lint": "next lint",
    "typecheck": "tsc --noEmit",
    "db:migrate": "tsx --env-file-if-exists=.env scripts/migrate.ts",
    "db:seed:volume": "tsx --env-file-if-exists=.env scripts/seed-volume.ts",
    "db:seed:production": "tsx --env-file-if-exists=.env scripts/seed-production.ts",
    "db:seed": "npm run db:seed:volume && npm run db:seed:production",
    "db:setup": "npm run db:migrate && npm run db:seed",
    "test": "tsx --test tests/*.test.ts"
  },
  "dependencies": {
    "csv-parse": "^5.5.6",
    "exceljs": "^4.4.0",
    "next": "^15.0.3",
    "next-auth": "^5.0.0-beta.25",
    "pg": "^8.13.1",
    "pptxgenjs": "^4.0.1",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "recharts": "^3.8.1"
  },
  "devDependencies": {
    "@types/jszip": "^3.4.0",
    "@types/node": "^22.10.1",
    "@types/pg": "^8.11.10",
    "@types/react": "^19.0.1",
    "@types/react-dom": "^19.0.2",
    "autoprefixer": "^10.4.20",
    "eslint": "^9.16.0",
    "eslint-config-next": "^15.0.3",
    "jszip": "^3.10.1",
    "postcss": "^8.4.49",
    "tailwindcss": "^3.4.16",
    "tsx": "^4.19.2",
    "typescript": "^5.7.2"
  }
}
