# Postgres on Railway — same instance as ultra1plus-pricing-core
# The u1d_ops schema is isolated inside that same database.
DATABASE_URL=postgresql://USER:PASSWORD@HOST:PORT/DATABASE

# NODE_ENV (Railway sets this to "production" automatically)
# NODE_ENV=development

# ----------------------------------------------------------------------------
# NextAuth (Phase 1.5 — not required for this MVP)
# ----------------------------------------------------------------------------
# NEXTAUTH_URL=https://dashboard.u1dynamics.com
# NEXTAUTH_SECRET=<generate with: openssl rand -base64 32>
# GOOGLE_CLIENT_ID=
# GOOGLE_CLIENT_SECRET=
