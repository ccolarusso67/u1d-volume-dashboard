# ============================================================================
# u1d-volume-dashboard — environment configuration
# ============================================================================

# ----------------------------------------------------------------------------
# Database
# ----------------------------------------------------------------------------
# Postgres on Railway — same instance as ultra1plus-pricing-core. The
# u1d_ops schema is isolated inside that same database.
DATABASE_URL=postgresql://USER:PASSWORD@HOST:PORT/DATABASE

# NODE_ENV (Railway sets this to "production" automatically)
# NODE_ENV=development

# ----------------------------------------------------------------------------
# Storage (Phase 1.7 — Railway Volume)
# ----------------------------------------------------------------------------
# Optional override for the storage root. Leave unset in production so the
# app resolves RAILWAY_VOLUME_MOUNT_PATH (set automatically by Railway when
# a volume is mounted at /app/storage). For local dev, point this at a
# directory you can write to.
# U1D_FILE_STORAGE_ROOT=/tmp/u1d-storage

# ----------------------------------------------------------------------------
# Authentication (PR 003A — NextAuth + Google OAuth)
# ----------------------------------------------------------------------------

# Required. Random 32+ byte string used to sign session JWTs. Generate with:
#   openssl rand -base64 32
# Rotate to invalidate every existing session.
NEXTAUTH_SECRET=

# Required in production. Public base URL of the deployed app. Auth.js uses
# this to construct OAuth callback URLs. Must match the URL Google sees.
#   - local dev:  http://localhost:3000
#   - production: https://dashboard.u1dynamics.com
NEXTAUTH_URL=http://localhost:3000

# Required. Google OAuth Client ID and Secret. Create at:
#   https://console.cloud.google.com/apis/credentials
# Authorized redirect URI for that OAuth client must include:
#   ${NEXTAUTH_URL}/api/auth/callback/google
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# Auth.js v5 also accepts these alternative names; prefer the ones above
# for consistency with prior deployments.
# AUTH_SECRET=
# AUTH_GOOGLE_ID=
# AUTH_GOOGLE_SECRET=

# ----------------------------------------------------------------------------
# Finance warehouse — read-only consumer (Phase 1.8 / PR 012A)
# ----------------------------------------------------------------------------
# Read-only Postgres connection to the Ultra1Plus Finance Railway DB
# (ultra1plus-finance-mcp). U1D-app pulls canonical P&L, AR/AP aging,
# and sync-health rows for U1Dynamics only. NEVER write to this DB.
#
# Provision a Postgres role with SELECT-only on the finance schema so the
# read-only contract is enforced at the DB layer too, not just in code.
#   CREATE ROLE u1d_finance_reader WITH LOGIN PASSWORD '...';
#   GRANT CONNECT ON DATABASE u1p_finance TO u1d_finance_reader;
#   GRANT USAGE ON SCHEMA public TO u1d_finance_reader;
#   GRANT SELECT ON ALL TABLES IN SCHEMA public TO u1d_finance_reader;
#
# Leave unset locally to fall back to volume-only views (the board pages
# render a "Finance data not configured" banner instead of crashing).
# U1D_FINANCE_DATABASE_URL=postgresql://u1d_finance_reader:PASSWORD@HOST:PORT/u1p_finance
